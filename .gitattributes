# Normalize line endings: commit all text with LF; pin per-type EOL.
# 'text=auto eol=lf' lets git classify text vs binary and forces LF.

* text=auto eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.mjs text eol=lf
*.ps1 text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
pnpm-lock.yaml text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.tar binary
*.jar binary
*.wasm binary
*.bin binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.mov binary
*.webm binary
*.mp3 binary
*.wav binary
